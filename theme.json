{
    "$schema": "https://schemas.wp.org/wp/7.0/theme.json",
    "version": 3,
    "settings": {
        "appearanceTools": true,
        "useRootPaddingAwareAlignments": true,
        "layout": {
            "contentSize": "760px",
            "wideSize": "1280px",
            "allowEditing": true,
            "allowCustomContentAndWideSize": true
        },
        "color": {
            "custom": true,
            "customGradient": true,
            "customDuotone": true,
            "defaultPalette": false,
            "defaultGradients": false,
            "defaultDuotone": false,
            "background": true,
            "text": true,
            "link": true,
            "heading": true,
            "button": true,
            "caption": true,
            "palette": [
                { "slug": "bg-canvas",       "name": "Canvas",          "color": "#08071A" },
                { "slug": "bg-panel",        "name": "Panel",           "color": "#0E0C24" },
                { "slug": "bg-raised",       "name": "Raised",          "color": "#15122F" },
                { "slug": "bg-inset",        "name": "Inset",           "color": "#1C183B" },
                { "slug": "fg-1",            "name": "Foreground 1",    "color": "#F4F2FA" },
                { "slug": "fg-2",            "name": "Foreground 2",    "color": "#E6E3F2" },
                { "slug": "fg-3",            "name": "Foreground 3",    "color": "#C7C3DA" },
                { "slug": "fg-4",            "name": "Foreground 4",    "color": "#938EAE" },
                { "slug": "fg-5",            "name": "Foreground 5",    "color": "#625E7C" },
                { "slug": "border-hair",     "name": "Border Hair",     "color": "#272248" },
                { "slug": "border-1",        "name": "Border",          "color": "#342D5A" },
                { "slug": "border-strong",   "name": "Border Strong",   "color": "#463E75" },
                { "slug": "accent",          "name": "Accent",          "color": "#9B1750" },
                { "slug": "accent-strong",   "name": "Accent Strong",   "color": "#7C0F3F" },
                { "slug": "accent-bright",   "name": "Accent Bright",   "color": "#E6317A" },
                { "slug": "accent-fg-on",    "name": "Accent Foreground","color": "#FFFFFF" },
                { "slug": "accent-2",        "name": "Accent 2",        "color": "#8B5CF6" },
                { "slug": "accent-2-strong", "name": "Accent 2 Strong", "color": "#7238DD" },
                { "slug": "link",            "name": "Link",            "color": "#22B8F0" },
                { "slug": "link-hover",      "name": "Link Hover",      "color": "#5CD4F6" },
                { "slug": "warn",            "name": "Warn",            "color": "#F59E24" },
                { "slug": "success",         "name": "Success",         "color": "#2BC678" },
                { "slug": "critical",        "name": "Critical",        "color": "#FF4D6D" },
                { "slug": "info",            "name": "Info",            "color": "#22B8F0" }
            ],
            "gradients": [
                { "slug": "voyager-magenta", "name": "Voyager Magenta", "gradient": "linear-gradient(135deg, #08071A 0%, #9B1750 60%, #E6317A 100%)" },
                { "slug": "voyager-violet",  "name": "Voyager Violet",  "gradient": "linear-gradient(135deg, #08071A 0%, #7238DD 60%, #8B5CF6 100%)" },
                { "slug": "voyager-aurora",  "name": "Voyager Aurora",  "gradient": "linear-gradient(135deg, #9B1750 0%, #8B5CF6 100%)" }
            ],
            "duotone": [
                { "slug": "voyager-magenta", "name": "Voyager Magenta", "colors": ["#08071A", "#E6317A"] },
                { "slug": "voyager-violet",  "name": "Voyager Violet",  "colors": ["#08071A", "#8B5CF6"] }
            ]
        },
        "typography": {
            "customFontSize": false,
            "defaultFontSizes": false,
            "dropCap": false,
            "fontStyle": true,
            "fontWeight": true,
            "letterSpacing": true,
            "lineHeight": true,
            "textAlign": true,
            "textDecoration": true,
            "textTransform": true,
            "fluid": {
                "minViewportWidth": "480px",
                "maxViewportWidth": "1600px"
            },
            "fontFamilies": [
                {
                    "slug": "display",
                    "name": "Voyager Display",
                    "fontFamily": "'Space Grotesk', 'Helvetica Neue', Arial, sans-serif"
                },
                {
                    "slug": "body",
                    "name": "Voyager Body",
                    "fontFamily": "'Inter', 'Helvetica Neue', Arial, sans-serif"
                },
                {
                    "slug": "mono",
                    "name": "Voyager Mono",
                    "fontFamily": "'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace"
                }
            ],
            "fontSizes": [
                { "slug": "xs",   "name": "XS",   "size": "clamp(0.75rem, 0.7rem + 0.25vw, 0.875rem)",   "fluid": false },
                { "slug": "sm",   "name": "SM",   "size": "clamp(0.875rem, 0.85rem + 0.25vw, 1rem)",     "fluid": false },
                { "slug": "base", "name": "Base", "size": "clamp(1rem, 0.95rem + 0.25vw, 1.125rem)",     "fluid": false },
                { "slug": "lg",   "name": "LG",   "size": "clamp(1.125rem, 1.05rem + 0.5vw, 1.375rem)",  "fluid": false },
                { "slug": "xl",   "name": "XL",   "size": "clamp(1.375rem, 1.2rem + 0.75vw, 1.75rem)",   "fluid": false },
                { "slug": "2xl",  "name": "2XL",  "size": "clamp(1.75rem, 1.4rem + 1.5vw, 2.5rem)",      "fluid": false },
                { "slug": "3xl",  "name": "3XL",  "size": "clamp(2.25rem, 1.7rem + 2.5vw, 3.5rem)",      "fluid": false },
                { "slug": "4xl",  "name": "4XL",  "size": "clamp(2.75rem, 2rem + 3.5vw, 4.5rem)",        "fluid": false },
                { "slug": "5xl",  "name": "5XL",  "size": "clamp(3.25rem, 2.3rem + 4.5vw, 5.75rem)",     "fluid": false }
            ]
        },
        "spacing": {
            "customSpacingSize": true,
            "units": ["px", "em", "rem", "vh", "vw", "%"],
            "spacingScale": {
                "operator": "*",
                "increment": 1.5,
                "steps": 7,
                "mediumStep": 1.5,
                "unit": "rem"
            }
        },
        "custom": {
            "color": {
                "surface":  { "dark": "var(--wp--preset--color--bg-canvas)" },
                "accent":   { "3":    "var(--wp--preset--color--accent)" }
            }
        }
    },
    "styles": {
        "color": {
            "background": "var(--wp--preset--color--bg-canvas)",
            "text":       "var(--wp--preset--color--fg-2)"
        },
        "typography": {
            "fontFamily":  "var(--wp--preset--font-family--body)",
            "fontSize":    "var(--wp--preset--font-size--base)",
            "lineHeight":  "1.6"
        },
        "elements": {
            "heading": {
                "typography": {
                    "fontFamily": "var(--wp--preset--font-family--display)",
                    "fontWeight": "600",
                    "lineHeight": "1.15",
                    "letterSpacing": "-0.02em"
                },
                "color": { "text": "var(--wp--preset--color--fg-1)" }
            },
            "link": {
                "color": { "text": "var(--wp--preset--color--link)" },
                ":hover": { "color": { "text": "var(--wp--preset--color--link-hover)" } }
            },
            "button": {
                "border": { "radius": "8px" },
                "typography": { "fontWeight": "600" },
                "color": {
                    "background": "var(--wp--preset--color--accent)",
                    "text":       "var(--wp--preset--color--accent-fg-on)"
                },
                ":hover": {
                    "color": {
                        "background": "var(--wp--preset--color--accent-bright)",
                        "text":       "var(--wp--preset--color--accent-fg-on)"
                    }
                }
            }
        }
    },
    "customTemplates": [
        {
            "name": "page-showcase",
            "postTypes": ["page", "vd_showcase"],
            "title": "Showcase Page"
        },
        {
            "name": "page-landing",
            "postTypes": ["page"],
            "title": "Landing Page (No Header/Footer)"
        },
        {
            "name": "page-no-title",
            "postTypes": ["page"],
            "title": "Page (No Title)"
        },
        {
            "name": "page-results",
            "postTypes": ["page"],
            "title": "Results Page"
        }
    ],
    "templateParts": [
        { "name": "header", "title": "Header", "area": "header" },
        { "name": "footer", "title": "Footer", "area": "footer" }
    ]
}
