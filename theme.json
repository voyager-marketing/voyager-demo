                        "2xl": "32px",
                        "3xl": "44px",
                        "4xl": "60px",
                        "5xl": "84px",
                        "6xl": "120px"
                    },
                    "fluid": {
                        "h1": "clamp(40px, 5vw + 16px, 84px)",
                        "h2": "clamp(32px, 3.5vw + 12px, 60px)",
                        "h3": "clamp(26px, 2vw + 10px, 44px)",
                        "display": "clamp(56px, 8vw + 8px, 120px)"
